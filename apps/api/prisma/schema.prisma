// Smeta AI — Prisma sxemasi (PostgreSQL)
// Multi-tenant qurilish smeta SaaS. Har Tenant — bitta mijoz-kompaniya.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  BOSHLANGICH
  PROFESSIONAL
  KORPORATIV
}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum UserRole {
  OWNER
  MANAGER
  ENGINEER
}

enum AdminRole {
  SUPERADMIN
  SUPPORT
}

enum ProjectStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum Currency {
  UZS
  USD
}

enum EstimateItemType {
  MATERIAL
  LABOR
  EQUIPMENT
}

// Ish haqi to'lash asosi (usta ishi turlari uchun).
// PER_UNIT — dona bo'yicha (masalan g'isht: dona × dona narxi).
enum PaymentType {
  PER_M2
  PER_M3
  PER_METER
  PER_UNIT
  FIXED
  HOURLY
}

enum EstimateStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum InvoiceStatus {
  PAID
  PENDING
  OVERDUE
  CANCELLED
}

enum ChatRole {
  user
  assistant
}

model Tenant {
  id          String       @id @default(cuid())
  name        String
  inn         String?
  phone       String?
  plan        Plan         @default(BOSHLANGICH)
  status      TenantStatus @default(TRIAL)
  trialEndsAt DateTime?
  usdRate     Decimal      @default(12600) @db.Decimal(18, 2) // 1 USD = X so'm (qo'lda kiritiladigan kurs)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  users       User[]
  projects    Project[]
  materials   Material[]
  estimates   Estimate[]
  activities  Activity[]
  chatSessions ChatSession[]
  invoices    Invoice[]
  sales       Sale[]
  realtors    Realtor[]
  generalExpenses generalExpenses[]
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fullName     String
  email        String   @unique
  phone        String?
  passwordHash String
  role         UserRole @default(OWNER)
  position     String?
  avatarUrl    String?
  language     String?  @default("uz") // interfeys tili: uz | ru
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  managedProjects Project[]    @relation("ProjectManager")
  activities      Activity[]
  chatSessions    ChatSession[]
  refreshTokens   RefreshToken[]

  @@index([tenantId])
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  fullName     String
  passwordHash String
  role         AdminRole @default(SUPPORT)
  createdAt    DateTime  @default(now())
}

// Refresh token rotatsiyasi + reuse-detection uchun.
// Opaque token (random) — DB'da faqat SHA-256 hash saqlanadi. Har refresh'da
// eski token bekor qilinib yangisi beriladi; bekor qilingan token qayta
// ishlatilsa — butun "family" (bir login sessiyasi) bekor qilinadi.
model RefreshToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  familyId   String
  kind       String // 'tenant' | 'admin'
  userId     String? // tenant foydalanuvchi (cascade)
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  adminId    String? // admin foydalanuvchi
  tenantId   String?
  role       String
  revokedAt  DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  @@index([familyId])
  @@index([userId])
  @@index([adminId])
}

model Project {
  id         String        @id @default(cuid())
  tenantId   String
  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code       String
  title      String
  clientName String
  category   String        @default("Umumiy")
  value      Decimal       @default(0) @db.Decimal(18, 2)
  currency   Currency      @default(UZS)
  deadline   DateTime?
  progress   Int           @default(0)
  status     ProjectStatus @default(PLANNED)
  managerId  String?
  manager    User?         @relation("ProjectManager", fields: [managerId], references: [id])
  // "Kelgan pullar" (loyiha = bino) uchun: honadonlar soni va binoni sotib olish narxi.
  totalUnits    Int     @default(0)
  purchasePrice Decimal @default(0) @db.Decimal(18, 2)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  estimates       Estimate[]
  sales           Sale[]
  generalExpenses generalExpenses[]

  @@index([tenantId])
}

model Material {
  id        String   @id @default(cuid())
  tenantId  String? // null = global katalog
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  category  String   @default("Umumiy")
  provider  String?
  unit      String   @default("dona")
  priceUzs  Decimal  @default(0) @db.Decimal(18, 2)
  priceUsd  Decimal  @default(0) @db.Decimal(18, 2)
  stock     Decimal  @default(0) @db.Decimal(18, 2)
  rating    Float    @default(0)
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([category])
}

model Estimate {
  id        String         @id @default(cuid())
  tenantId  String
  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  title     String
  currency  Currency       @default(UZS)
  taxRate   Float          @default(12)
  subtotal  Decimal        @default(0) @db.Decimal(18, 2)
  taxAmount Decimal        @default(0) @db.Decimal(18, 2)
  total     Decimal        @default(0) @db.Decimal(18, 2)
  status    EstimateStatus @default(DRAFT)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  items     EstimateItem[]
  stages    EstimateStage[]

  @@index([tenantId])
}

model EstimateItem {
  id          String           @id @default(cuid())
  estimateId  String
  estimate    Estimate         @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  materialId  String?
  name        String
  type        EstimateItemType @default(MATERIAL)
  paymentType PaymentType? // ish haqi asosi (usta ishi turlari uchun)
  qty         Decimal          @default(0) @db.Decimal(18, 3)
  unit        String           @default("dona")
  unitPrice   Decimal          @default(0) @db.Decimal(18, 2)
  lineTotal   Decimal          @default(0) @db.Decimal(18, 2)

  @@index([estimateId])
}

// Smeta muddatlari / bosqichlari (kalkulyator "Muddatlar" bo'limi).
model EstimateStage {
  id         String    @id @default(cuid())
  estimateId String
  estimate   Estimate  @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  label      String
  date       DateTime?
  amount     Decimal   @default(0) @db.Decimal(18, 2)
  currency   Currency  @default(UZS)
  order      Int       @default(0)

  @@index([estimateId])
}

model Activity {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action      String
  projectName String?
  createdAt   DateTime @default(now())

  @@index([tenantId])
}

model ChatSession {
  id        String        @id @default(cuid())
  tenantId  String
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  title     String        @default("Yangi suhbat")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  messages  ChatMessage[]

  @@index([tenantId])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      ChatRole
  content   String      @db.Text
  createdAt DateTime    @default(now())

  @@index([sessionId])
}

model Invoice {
  id       String        @id @default(cuid())
  tenantId String
  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  amount   Decimal       @default(0) @db.Decimal(18, 2)
  currency Currency      @default(UZS)
  period   String
  status   InvoiceStatus @default(PENDING)
  issuedAt DateTime      @default(now())
  paidAt   DateTime?

  @@index([tenantId])
}

// Sotilgan honadonlar (kelgan pullar)
model Sale {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projectId  String? // qaysi binoga (loyihaga) tegishli
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  unitName   String
  buyerName  String
  buyerPhone String? // xonadon egasining telefon raqami
  area       Decimal  @default(0) @db.Decimal(18, 2)
  price      Decimal  @default(0) @db.Decimal(18, 2)
  paid       Decimal  @default(0) @db.Decimal(18, 2)
  currency   Currency @default(UZS)
  soldAt     DateTime @default(now())
  createdAt  DateTime @default(now())

  // Makler/realtor orqali sotuv (ixtiyoriy)
  realtorId        String?
  realtor          Realtor? @relation(fields: [realtorId], references: [id], onDelete: SetNull)
  commissionAmount Decimal  @default(0) @db.Decimal(18, 2)

  payments Payment[]

  @@index([tenantId])
  @@index([realtorId])
  @@index([projectId])
}

// Makler / Realtor — uy sotuvchi vositachilar
model Realtor {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales Sale[]

  @@index([tenantId])
}
model Payment {
  id         String   @id @default(cuid())
  saleId     String
  sale       Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  amount     Decimal  @db.Decimal(18, 2)
  currency   Currency @default(UZS)
  location   String?  // "qayerda berdi": Ofis, Qurilish maydoni, Bank o'tkazma...
  method     String?  // naqd, karta, o'tkazma
  note       String?
  paidAt     DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([saleId])
}
// Umumiy harajatlar — kalkulyator bo'limi (tenant profiliga serverda saqlanadi)
model generalExpenses {
  id        Int      @id @default(autoincrement())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projectId String? // qaysi binoga (loyihaga) tegishli; null = umumiy
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label     String
  amount    Float
  currency  String   @default("UZS")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([projectId])
}