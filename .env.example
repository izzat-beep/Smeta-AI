# ─── Database (PostgreSQL) ───────────────────────────────────────────────
# Lokal (docker-compose): postgresql://smeta:smeta@localhost:5432/smeta?schema=public
# Railway/Render: managed Postgres connection string'ini qo'ying
DATABASE_URL="postgresql://smeta:smeta@localhost:5432/smeta?schema=public"

# ─── Auth ────────────────────────────────────────────────────────────────
JWT_SECRET="dev-juda-maxfiy-kalit-prodda-almashtiring"
JWT_REFRESH_SECRET="dev-refresh-maxfiy-kalit-prodda-almashtiring"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Claude AI (AI Konsultant chat) ──────────────────────────────────────
# https://console.anthropic.com dan oling
ANTHROPIC_API_KEY=""
# claude-opus-4-8 (eng kuchli) | claude-sonnet-4-6 (tezroq/arzonroq)
AI_MODEL="claude-opus-4-8"

# ─── AI chat cheklovlari (xarajat nazorati — barchasi ixtiyoriy) ──────────
# Bo'sh qoldirilsa quyidagi xavfsiz standart qiymatlar ishlatiladi.
AI_CHAT_MAX_MESSAGE_CHARS=4000   # bitta xabar maks. uzunligi (belgi)
AI_CHAT_HISTORY_LIMIT=20         # Claude'ga yuboriladigan oxirgi xabarlar soni
AI_CHAT_HISTORY_MAX_CHARS=24000  # tarix uchun taxminiy token budjeti (belgi)
AI_CHAT_DAILY_LIMIT=100          # tenant bo'yicha kunlik chat so'rovlari
AI_CHAT_HOURLY_LIMIT=40          # foydalanuvchi bo'yicha soatlik chat so'rovlari
AI_CHAT_MAX_TOKENS=2048          # Claude javobi uchun maks. token

# ─── Ovozli buyruq STT (OpenAI Whisper) ──────────────────────────────────
# Bo'sh bo'lsa demo rejim: brauzerning Web Speech API'si ishlatiladi.
# Kalit qo'shilsa server Whisper orqali audio'ni matnga aylantiradi.
OPENAI_API_KEY=""
WHISPER_MODEL="whisper-1"

# ─── Server ──────────────────────────────────────────────────────────────
API_PORT=4000
# Frontend originlari (CORS) — vergul bilan ajrating
WEB_ORIGIN="http://localhost:5173"
ADMIN_ORIGIN="http://localhost:5174"
NODE_ENV="development"

# ─── Frontend (build vaqtida) ────────────────────────────────────────────
VITE_API_URL="http://localhost:4000"
