# VPS (production) uchun. VPS'da nusxa oling:  cp .env.prod.example .env
# Domeningiz (admin avtomatik admin.DOMAIN bo'ladi).
# MUHIM: DOMAIN CORS uchun ham ishlatiladi — https://DOMAIN va https://admin.DOMAIN
# avtomatik ruxsat etilgan originlarga qo'shiladi. Domensiz (masalan IP) ishlatsangiz
# yoki qo'shimcha origin kerak bo'lsa, quyidagi CORS_ORIGINS ni to'ldiring.
DOMAIN=smeta-ai.uz
# SSL sertifikat uchun emailingiz
ACME_EMAIL=siz@email.uz

# (Ixtiyoriy) Qo'shimcha ruxsat etilgan originlar — vergul bilan, sxema bilan.
# Masalan IP orqali kirish yoki www subdomeni uchun:
#   CORS_ORIGINS=http://195.158.1.2,https://www.smeta-ai.uz
CORS_ORIGINS=

# Baza paroli — MAJBURIY (o'rnatilmasa deploy to'xtaydi). Kuchli/tasodifiy qiling:
#   openssl rand -base64 24
DB_PASSWORD=

# JWT kalitlar (tasodifiy uzun matn). Yaratish: openssl rand -hex 32
JWT_SECRET=buni-tasodifiy-uzun-matnga-almashtiring
JWT_REFRESH_SECRET=buni-ham-boshqa-tasodifiy-matnga

# Super admin (birinchi deploy'da bootstrap yaratadi). MAJBURIY:
# parol kamida 10 belgi, namuna/dev parollar (admin1234 va h.k.) rad etiladi.
ADMIN_EMAIL=admin@sizning-domeningiz.uz
ADMIN_PASSWORD=

# Claude AI kaliti (console.anthropic.com). Bo'sh bo'lsa AI demo rejimda ishlaydi.
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8

# Ovozli buyruq STT (OpenAI Whisper). Bo'sh bo'lsa brauzer Web Speech API (demo).
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1
